{
  "expo": {
    "name": "Kalam Kaar",
    "slug": "kalam",
    "version": "1.0.0",
    "icon": "./icon.png",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "extra": {
      "eas": {
