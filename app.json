        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.gourav911.kalam",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "ios": {
      "bundleIdentifier": "com.gourav911.kalam"
    }
  }
}